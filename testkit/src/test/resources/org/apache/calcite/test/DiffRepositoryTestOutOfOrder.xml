<Root>
  <!-- These test cases are intentionally OUT OF ORDER to test CALCITE-4593.
       When DiffRepository loads this file, it should detect that testZoo comes
       before testBar (which violates alphabetical order) and raise an error
       when checkActualAndReferenceFiles() is called. -->
  <TestCase name="testZoo">
    <Resource name="data">
      <![CDATA[This test case name comes after testBar alphabetically]]>
    </Resource>
  </TestCase>
  <TestCase name="testBar">
    <Resource name="data">
      <![CDATA[This test case name comes before testZoo alphabetically]]>
    </Resource>
  </TestCase>
  <TestCase name="testFoo">
    <Resource name="data">
      <![CDATA[This test case is in the middle]]>
    </Resource>
  </TestCase>
</Root>
